{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "alpha-wallet-mirror",
  "account_id": "5d39e0d1c74578fc6762947412e84add",
  "main": ".open-next/worker.js",
  "compatibility_date": "2026-06-21",
  "compatibility_flags": ["nodejs_compat"],
  "send_email": [
    {
      "name": "EMAIL"
    }
  ],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "kv_namespaces": [
    {
      "binding": "DATA_KV",
      "id": "d17fd1e288ee414c9a1b89db3996a7a6"
    }
  ],
  "routes": [
    {
      "pattern": "alphamirror.trade",
      "custom_domain": true
    },
    {
      "pattern": "www.alphamirror.trade",
      "custom_domain": true
    }
  ],
  "workers_dev": true,
  "vars": {
    "NEXT_PUBLIC_SUPPORT_AGENT_URL": "https://alpha-wallet-support.alpha-wallet.workers.dev",
    "NEXT_PUBLIC_TURNSTILE_SITE_KEY": "0x4AAAAAADpHET5z-RwtU2Sn",
