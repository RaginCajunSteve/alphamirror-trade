    "NEXT_PUBLIC_MIRROR_ROUTER_ADDRESS": "0x1e282104732827dcf63bfc958a778f5116330fcc",
    "NEXT_PUBLIC_MIRROR_ROUTER_ARBITRUM": "0xefe995d1f4ff06dc0cf08d1bcbdae74e5f99deb4",
